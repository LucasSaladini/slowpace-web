generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  hobbies Hobby[]

  @@map("users")
}

model Hobby {
  id        String    @id @default(uuid())
  name      String
  color     String?
  frequency String    @default("daily")
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  sessions  Session[]
}

model Session {
  id        String   @id @default(uuid())
  duration  Int
  content   String?
  createdAt DateTime @default(now())
  hobbyId   String
  hobby     Hobby    @relation(fields: [hobbyId], references: [id])
}
